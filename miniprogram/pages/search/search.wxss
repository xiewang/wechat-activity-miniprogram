/**pages/search/search.wxss**/

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-icon {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

.filter-btn {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 筛选面板 */
.filter-panel {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-section {
  margin-bottom: 24rpx;
}

.filter-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-option.active {
  background: #e8f5e9;
  color: #4CAF50;
}

.filter-actions {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.clear-filters {
  font-size: 28rpx;
  color: #999;
}

.close-filters {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 当前筛选 */
.active-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff;
}

.filter-tag {
  padding: 8rpx 20rpx;
  background: #e8f5e9;
  color: #4CAF50;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 结果列表 */
.result-list {
  padding: 20rpx;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-item:active {
  opacity: 0.8;
}

.item-header {
  margin-bottom: 16rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.info-text.deadline {
  color: #f44336;
}

.item-organizer {
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}
